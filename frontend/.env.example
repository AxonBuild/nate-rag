# Clerk (Vite requires VITE_ prefix — not NEXT_PUBLIC_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Roles: Clerk Dashboard → Users → Public metadata → { "role": "admin" }
# Omit or use "client" for normal users (default).

# URL of the deployed FastAPI backend (no trailing slash)
# In dev, leave empty — vite.config.js proxies API calls to localhost:8000
VITE_API_URL=
